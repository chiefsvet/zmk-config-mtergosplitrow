#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,physical-layout = &layout;
    };

    kscan: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";

        row-gpios = <&pro_micro 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                    <&pro_micro 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                    <&pro_micro 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                    <&pro_micro 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                    <&pro_micro 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
    };

    transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        rows = <5>;
        columns = <15>;

        map = <
                RC(0, 0) RC(0, 1) RC(0, 2) RC(0, 3) RC(0, 4) RC(0, 5) RC(0, 6) RC(0, 7) RC(0,8)  RC(0, 9) RC(0, 10) RC(0, 11) RC(0, 12) RC(0, 13) RC(0, 14)
                RC(1, 0) RC(1, 1) RC(1, 2) RC(1, 3) RC(1, 4) RC(1, 5) RC(1, 6)                   RC(1, 9) RC(1, 10) RC(1, 11) RC(1, 12) RC(1, 13) RC(1, 14)
                RC(2, 0) RC(2, 1) RC(2, 2) RC(2, 3) RC(2, 4) RC(2, 5) RC(2, 6)                   RC(2, 9) RC(2, 10) RC(2, 11) RC(2, 12) RC(2, 13) RC(2, 14)
                RC(3, 0) RC(3, 1) RC(3, 2) RC(3, 3) RC(3, 4) RC(3, 5) RC(3, 6)                   RC(3, 9) RC(3, 10) RC(3, 11) RC(3, 12) RC(3, 13) RC(3, 14)
                                           RC(4, 3) RC(4, 4) RC(4, 5) RC(4, 6) RC(4, 7)          RC(4, 9) RC(4, 10) RC(4, 11) RC(4, 12) RC(2, 13)
        >;
    };

    layout: layout {
        compatible = "zmk,physical-layout";
        display-name = "mtErgoSplitRow";
        transform = <&transform>;
        kscan = <&kscan>;
        // Row 0                   w    h    x       y        rot   rx    ry
        keys 
            = <&key_physical_attrs 100 100   0       50       0     0     0> /* M1 */
            , <&key_physical_attrs 100 100   150     50       0     0     0> /* esc */
            , <&key_physical_attrs 100 100   250     50       0     0     0> /* 1 */
            , <&key_physical_attrs 100 100   350     25       0     0     0> /* 2 */
            , <&key_physical_attrs 100 100   450     0        0     0     0> /* 3 */
            , <&key_physical_attrs 100 100   550     25       0     0     0> /* 4 */
            , <&key_physical_attrs 100 100   650     50       0     0     0> /* 5 */
            , <&key_physical_attrs 100 100   750     50       0     0     0> /* 6 */
            , <&key_physical_attrs 100 100   1050    50       0     0     0> /* Rot Enc Push */
            , <&key_physical_attrs 100 100   1150    50       0     0     0> /* 7 */
            , <&key_physical_attrs 100 100   1250    25       0     0     0> /* 8 */
            , <&key_physical_attrs 100 100   1350    0        0     0     0> /* 9 */
            , <&key_physical_attrs 100 100   1450    25       0     0     0> /* 0 */
            , <&key_physical_attrs 100 100   1550    50       0     0     0> /* - _ = + */
            , <&key_physical_attrs 100 100   1650    50       0     0     0> /* BKSP */
       
        //Row 1                    w    h    x       y        rot   rx    ry

            , <&key_physical_attrs 100 100   0       150       0     0     0> /* M2 */
            , <&key_physical_attrs 100 100   150     150       0     0     0> /* Tab */
            , <&key_physical_attrs 100 100   250     150       0     0     0> /* Q */
            , <&key_physical_attrs 100 100   350     125       0     0     0> /* W */
            , <&key_physical_attrs 100 100   450     100       0     0     0> /* E */
            , <&key_physical_attrs 100 100   550     125       0     0     0> /* R */
            , <&key_physical_attrs 100 100   650     150       0     0     0> /* T */
            , <&key_physical_attrs 100 100   1150    150       0     0     0> /* Y */
            , <&key_physical_attrs 100 100   1250    125       0     0     0> /* U */
            , <&key_physical_attrs 100 100   1350    100       0     0     0> /* I */
            , <&key_physical_attrs 100 100   1450    125       0     0     0> /* O */
            , <&key_physical_attrs 100 100   1550    150       0     0     0> /* P */
            , <&key_physical_attrs 100 100   1650    150       0     0     0> /* \ | */

        //Row 2                    w    h    x       y        rot   rx    ry

            , <&key_physical_attrs 100 100   0       250       0     0     0> /* M3 */
            , <&key_physical_attrs 100 100   150     250       0     0     0> /* Capslock */
            , <&key_physical_attrs 100 100   250     250       0     0     0> /* A */
            , <&key_physical_attrs 100 100   350     225       0     0     0> /* S */
            , <&key_physical_attrs 100 100   450     200       0     0     0> /* D */
            , <&key_physical_attrs 100 100   550     225       0     0     0> /* F */
            , <&key_physical_attrs 100 100   650     250       0     0     0> /* G */
            , <&key_physical_attrs 100 100   1150    250       0     0     0> /* H */
            , <&key_physical_attrs 100 100   1250    225       0     0     0> /* J */
            , <&key_physical_attrs 100 100   1350    200       0     0     0> /* K */
            , <&key_physical_attrs 100 100   1450    225       0     0     0> /* L */
            , <&key_physical_attrs 100 100   1550    250       0     0     0> /* ; : ' " */
            , <&key_physical_attrs 100 100   1650    250       0     0     0> /* Return */

        // Row 3                   w    h    x       y        rot   rx    ry

            , <&key_physical_attrs 100 100   0       350       0     0     0> /* M4 */
            , <&key_physical_attrs 100 100   150     350       0     0     0> /* Shift */
            , <&key_physical_attrs 100 100   250     350       0     0     0> /* Z */
            , <&key_physical_attrs 100 100   350     325       0     0     0> /* X */
            , <&key_physical_attrs 100 100   450     300       0     0     0> /* C */
            , <&key_physical_attrs 100 100   550     325       0     0     0> /* V */
            , <&key_physical_attrs 100 100   650     350       0     0     0> /* B */
            , <&key_physical_attrs 100 100   1150    350       0     0     0> /* N */
            , <&key_physical_attrs 100 100   1250    325       0     0     0> /* M */
            , <&key_physical_attrs 100 100   1350    300       0     0     0> /* , < */
            , <&key_physical_attrs 100 100   1450    325       0     0     0> /* . > */
            , <&key_physical_attrs 100 100   1550    350       0     0     0> /* / ? " */
            , <&key_physical_attrs 100 100   1650    350       0     0     0> /* Shift */

        // Row 4                   w   h  v  x       y        rot       rx    ry 
            , <&key_physical_attrs 100 100   300     460      0         50    0> /* Left ctrl */
            , <&key_physical_attrs 100 100   450     425      500       0     0> /* Left opt */
            , <&key_physical_attrs 100 100   600     400      1000      0     0> /* Left cmd */
            , <&key_physical_attrs 100 175   775     225      2000      0     0> /* Left space */
            , <&key_physical_attrs 100 175   875     225      2000      0     0> /* Raise right */
            , <&key_physical_attrs 100 175   825     850      (-2000)   0     0> /* Raise left */
            , <&key_physical_attrs 100 175   925     850      (-2000)   0     0> /* Right space */
            , <&key_physical_attrs 100 100   1180    725      (-1000)   0     0> /* Right cmd */
            , <&key_physical_attrs 100 100   1350    600      (-500)    0     0> /* Right opt */
            , <&key_physical_attrs 100 100   1500    475       0        0     0> /* Fn */
            ;
    };
}; 